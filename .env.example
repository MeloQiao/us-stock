# Alpaca Paper Trading
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Paper trading base URL (do not change)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Feishu (Lark) Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# Hugging Face (for data persistence)
HF_TOKEN=your_hf_token
HF_DATASET_REPO=your_username/us-stock-data

# Optional: Alpha Vantage (fallback real-time quotes)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
